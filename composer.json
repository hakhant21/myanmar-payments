{
  "name": "hakhant/myanmar-payments",
  "description": "Laravel Myanmar payment gateway package for KBZPay, WaveMoney, 2C2P, AYA Pay, and MMQR.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "payments",
    "myanmar",
    "myanmar-payments",
    "payment-gateway",
    "kbzpay",
    "wavemoney",
    "wavepay",
    "2c2p",
    "ayapay",
    "mmqr"
  ],
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "firebase/php-jwt": "^7.0",
    "phpseclib/phpseclib": "^3.0"
  },
  "require-dev": {
    "laravel/pint": "^1.17",
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0",
    "phpstan/phpstan": "^1.11",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Hakhant\\Payments\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Hakhant\\Payments\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Hakhant\\Payments\\Providers\\MyanmarPaymentsServiceProvider"
      ],
      "aliases": {
        "MyanmarPayments": "Hakhant\\Payments\\Facades\\MyanmarPayments"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test:coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage --coverage-text",
    "format": "vendor/bin/pint",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G --xdebug",
    "refactor": "vendor/bin/rector process --xdebug",
    "quality": [
      "@test",
      "@test:coverage",
      "@format",
      "@analyse",
      "@refactor"
    ],
    "release": "bash release.sh"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
